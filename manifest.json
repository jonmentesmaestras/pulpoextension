{
  "action": {
    "default_icon": {
      "32": "images/icon.png"
    },
    "default_name": "ClicSpy",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "css": [
        "./fontawesome.css",
        "./country.css",
        "style.css",
        "./tippy.css",
        "./category.css"
      ],
      "js": [
        "./lib/jquery.js",
        "./countries2.js",
        "./lib/popper.js",
        "./lib/tippy.js",
        "./lib/extractDate.js",
        "initialize.js",
        "ContentScript.js",
        "./lib/FileSaver.js"
        
      ],
      "matches": ["https://*.facebook.com/*"]
    },
    {
      "js": ["dashboard.js"],
      "matches": ["https://app.pulpoia.com/*"]
    }
  ],
  "host_permissions": [
    "https://tueducaciondigital.site/",
    "https://app.pulpoia.com/",
    "https://fonts.googleapis.com/",
    "https://www.facebook.com/ads/library/"
  ],
  "icons": {
    "128": "images/icon128.png",
    "16": "images/icon16.png",
    "48": "images/icon48.png"
  },

  "manifest_version": 3,
  "name": "PulpoIA",
  "permissions": ["storage", "activeTab", "webNavigation"],
  "update_url": "https://clients2.google.com/service/update2/crx",
  "version": "1.0.0",

  "web_accessible_resources": [
    {
      "matches": ["\u003Call_urls>"],
      "resources": ["*"]
    }
  ]
}
